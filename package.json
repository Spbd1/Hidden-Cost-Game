{
  "name": "hidden-cost-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/validate-production-env.mjs && next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:dev": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "validate:sample": "tsx scripts/validate-sample-export.ts",
    "export:submissions": "tsx scripts/export-submissions.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "next": "^14.2.23",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.23",
    "postcss": "^8.4.49",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  },
  "description": "A web-based research prototype for studying decision-making and outcome interpretation under incomplete information.",
  "author": "Dr. Mohammad Moradi",
  "repository": {
    "type": "git",
    "url": "https://github.com/Spbd1/Hidden-Cost-Game.git"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22 <25"
  }
}
